PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=24h
AUTH_CHALLENGE_TTL_SECONDS=300
ENABLE_ONCHAIN_ROLE_RESOLUTION=true

# Active chain: celoSepolia (default) or celo (mainnet)
CHAIN_NETWORK=celoSepolia

# Optional: skip on-chain role checks in local dev (validators/government routes)
# DEV_BYPASS_ROLE_GUARDS=true

# Blockchain RPC URLs
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
CELO_RPC_URL=https://forno.celo.org

# Relayer key for validator/government relayed writes (validateLot, releasePayment, publishNews, issueMark)
# Leave empty to disable relayed writes — wallet-direct flows still work.
RELAYER_PRIVATE_KEY=

# Contract addresses — prefer from repo root:
#   npm run use:sepolia   or   npm run use:mainnet
NEWS_BULLETIN_ADDRESS=
HARVEST_LEDGER_ADDRESS=
FARMER_MARKET_ADDRESS=
INDUSTRY_MARK_REGISTRY_ADDRESS=
PROOF_OF_ORIGIN_VERIFIER_ADDRESS=
GAS_SUBSIDY_POOL_ADDRESS=
DISPUTE_RESOLUTION_ADDRESS=
REPUTATION_SYSTEM_ADDRESS=
PRICE_ORACLE_ADDRESS=
MULTI_SIG_TREASURY_ADDRESS=

# The Graph subgraph (indexed chain data for lots, offers, marks, news)
GRAPHQL_ENDPOINT=https://api.studio.thegraph.com/query/YOUR_SUBGRAPH_ID

# --- IPFS (pick one option below) ---

# Option 1: Dev fallback (default in development) — stores metadata under api/data/ipfs-dev/
IPFS_DEV_FALLBACK=true

# Option 2: Pinata (easiest production setup)
# PINATA_JWT=eyJ...
# IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# Option 3: Infura IPFS (requires IPFS product approval on your Infura account)
IPFS_API_URL=https://ipfs.infura.io:5001/api/v0
INFURA_JWT_KEY_ID=
INFURA_JWT_PRIVATE_KEY_PATH=./secrets/infura-jwt-private.pem
IPFS_GATEWAY=https://ipfs.io/ipfs

# Option 4: Local IPFS node (ipfs daemon)
# IPFS_PROVIDER=local
# IPFS_API_URL=http://127.0.0.1:5001/api/v0
