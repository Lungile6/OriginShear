# IPFS options (pick one)

# --- Option 1: Dev fallback (default in development) ---
# If remote IPFS fails, metadata is saved under api/data/ipfs-dev/ and lot registration continues.
IPFS_DEV_FALLBACK=true

# --- Option 2: Pinata (easiest production setup) ---
# PINATA_JWT=eyJ...
# IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# --- Option 3: Infura IPFS (requires IPFS product approval on your Infura account) ---
IPFS_API_URL=https://ipfs.infura.io:5001/api/v0
INFURA_JWT_KEY_ID=
INFURA_JWT_PRIVATE_KEY_PATH=./secrets/infura-jwt-private.pem
IPFS_GATEWAY=https://ipfs.io/ipfs

# --- Option 4: Local IPFS node (ipfs daemon) ---
# IPFS_PROVIDER=local
# IPFS_API_URL=http://127.0.0.1:5001/api/v0
