# API and RPC
VITE_API_BASE_URL=http://localhost:3000
# Active chain: celoSepolia (testnet, default) or celo (mainnet)
VITE_CHAIN_NETWORK=celoSepolia
VITE_CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
VITE_CELO_RPC_URL=https://forno.celo.org
VITE_IPFS_GATEWAY=https://ipfs.io/ipfs

# Optional WalletConnect project ID (https://cloud.walletconnect.com) for Valora / mobile QR
# VITE_WALLETCONNECT_PROJECT_ID=

# Optional: skip on-chain role guards so all routes are reachable in local dev
VITE_DEV_BYPASS_ROLE_GUARDS=false

# Celo Sepolia contract addresses — run from repo root:
#   npm run use:sepolia
# Or paste from originshear-contracts/deployments.celoSepolia.json
VITE_CELO_SEPOLIA_HARVEST_LEDGER=
VITE_CELO_SEPOLIA_FARMER_MARKET=
VITE_CELO_SEPOLIA_VERIFIER=
VITE_CELO_SEPOLIA_INDUSTRY_MARK_REGISTRY=
VITE_CELO_SEPOLIA_NEWS_BULLETIN=
VITE_CELO_SEPOLIA_GAS_SUBSIDY_POOL=
VITE_CELO_SEPOLIA_DISPUTE_RESOLUTION=
VITE_CELO_SEPOLIA_REPUTATION_SYSTEM=
VITE_CELO_SEPOLIA_PRICE_ORACLE=
VITE_CELO_SEPOLIA_MULTI_SIG_TREASURY=

# Alfajores Contract Addresses
VITE_ALFAJORES_HARVEST_LEDGER=
VITE_ALFAJORES_FARMER_MARKET=
VITE_ALFAJORES_VERIFIER=

# Celo Mainnet Contract Addresses — after deploy: npm run use:mainnet
VITE_CELO_HARVEST_LEDGER=
VITE_CELO_FARMER_MARKET=
VITE_CELO_VERIFIER=
VITE_CELO_INDUSTRY_MARK_REGISTRY=
VITE_CELO_NEWS_BULLETIN=
VITE_CELO_GAS_SUBSIDY_POOL=
VITE_CELO_DISPUTE_RESOLUTION=
VITE_CELO_REPUTATION_SYSTEM=
VITE_CELO_PRICE_ORACLE=
VITE_CELO_MULTI_SIG_TREASURY=

# Local / Hardhat Contract Addresses
VITE_LOCAL_HARVEST_LEDGER=
VITE_LOCAL_FARMER_MARKET=
VITE_LOCAL_VERIFIER=
VITE_LOCAL_INDUSTRY_MARK_REGISTRY=
VITE_LOCAL_MOCK_CUSD=
